---
/**
 * Demo playground — default theme, mock SSE backend (./api/chat.ts).
 * Run with `npm run demo`. Also the stage for README screenshots.
 *
 * The two frames are iframes of ./embed.astro — the live widget playing a
 * scripted conversation on a loop (a "gif" that can't go stale): the desktop
 * glass panel over a light skeleton page, and the mobile sheet rebranded via
 * ?accent. The real interactive instance is the FAB in the corner.
 */
import AIChat from '../../src/AIChat.astro'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover, interactive-widget=resizes-content"
    />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>&#128172;</text></svg>" />
    <title>astro-chat-widget — demo</title>
  </head>
  <body>
    <nav class="corner" aria-label="Project links">
      <a
        class="pill gh"
        href="https://github.com/eeegoloauq/astro-chat-widget"
        target="_blank"
        rel="noopener"
        aria-label="astro-chat-widget on GitHub"
      >
        <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
        </svg>
        GitHub
        <span class="count" hidden>
          <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor" aria-hidden="true">
            <path d="M8 .25a.75.75 0 0 1 .67.42l1.88 3.8 4.2.62c.61.09.86.84.41 1.28l-3.04 2.96.72 4.18a.75.75 0 0 1-1.09.79L8 12.35l-3.75 1.97a.75.75 0 0 1-1.09-.79l.72-4.18L.84 6.37a.75.75 0 0 1 .41-1.28l4.2-.61L7.33.67A.75.75 0 0 1 8 .25Z"/>
          </svg>
          <span data-count></span>
        </span>
      </a>
      <a
        class="pill npm"
        href="https://www.npmjs.com/package/astro-chat-widget"
        target="_blank"
        rel="noopener"
        aria-label="astro-chat-widget on npm"
        title="Weekly downloads on npm"
      >
        <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true">
          <path d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0zM5.13 5.323l13.837.019-.009 13.836h-3.464l.01-10.382h-3.456L12.04 19.17H5.113z"/>
        </svg>
        npm
        <span class="count" hidden>
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 4v11m0 0 5-5m-5 5-5-5M5 20h14"/>
          </svg>
          <span data-count></span>
        </span>
      </a>
    </nav>

    <main>
      <h1>astro-chat-widget</h1>
      <p class="hint">
        Live demo, mock backend — try it yourself:
        <a href="#chat" data-acw-open>the bubble ↘</a>
      </p>

      <button class="install" type="button" title="Copy to clipboard">
        <code>npm install astro-chat-widget</code>
        <svg class="install-copy" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="12" height="12" rx="2.5"/><path d="M5 15H4.5A1.5 1.5 0 0 1 3 13.5v-9A1.5 1.5 0 0 1 4.5 3h9A1.5 1.5 0 0 1 15 4.5V5"/>
        </svg>
        <svg class="install-check" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 12.5 9.5 18 20 6.5"/>
        </svg>
      </button>

      <div class="frames" aria-hidden="true">
        <figure class="device device--desktop">
          <div class="chrome">
            <span class="chrome-dots"><i></i><i></i><i></i></span>
            <span class="chrome-url">yoursite.dev</span>
          </div>
          <div class="chrome-viewport">
            <iframe src="/embed?desktop" title="" tabindex="-1"></iframe>
          </div>
          <figcaption><code>&lt;AIChat endpoint="/api/chat" /&gt;</code></figcaption>
        </figure>

        <figure class="device device--phone">
          <iframe src="/embed?accent=%23e31e24&start=2&lag=4800" title="" tabindex="-1"></iframe>
          <figcaption><code>--acw-accent: #e31e24</code></figcaption>
        </figure>
      </div>
    </main>

    <AIChat
      endpoint="/api/chat"
      feedbackEndpoint="/api/feedback"
      quickReplies={[
        {
          text: 'What can this widget do?',
          answer: [
            'Everything on this page ships as **one Astro component**:',
            '',
            '- Streaming answers over SSE, markdown rendered append-only',
            '- Native `<dialog>` — floating panel on desktop (the page stays scrollable), iOS-keyboard-proof sheet on mobile',
            '- Theming via `--acw-*` tokens — one accent variable to rebrand',
            '- FAQ chips like this one answer **instantly, without a backend call**',
            '',
            'Zero framework runtime, one dependency.',
          ].join('\n'),
          followUps: [
            {
              text: 'Does it need a backend?',
              answer: [
                'For AI answers, yes — any endpoint speaking the tiny SSE protocol from the README (`{chunk}` events, then `{done}`).',
                '',
                'But chips with a canned `answer` — like this one — render locally. A pure FAQ tree needs **no backend at all**.',
              ].join('\n'),
              followUps: [{ text: 'How do I theme it?' }],
            },
            { text: 'Show markdown rendering' },
          ],
        },
        { text: 'How do I theme it?' },
        { text: 'What about the iOS keyboard?' },
      ]}
    />
  </body>
</html>

<script>
  // Live counts for the corner pills (GitHub stars, npm weekly downloads).
  // Both APIs are unauthenticated with per-visitor-IP quotas — a session
  // cache keeps reloads free. On any failure the pill stays a plain link;
  // the count is garnish.
  const compact = (n: number) => new Intl.NumberFormat('en', { notation: 'compact' }).format(n)
  async function liveCount(
    pill: string,
    key: string,
    url: string,
    pick: (data: any) => number,
    fmt: (n: number) => string
  ) {
    const wrap = document.querySelector<HTMLElement>(`${pill} .count`)
    const out = wrap?.querySelector<HTMLElement>('[data-count]')
    if (!wrap || !out) return
    try {
      const cached = JSON.parse(sessionStorage.getItem(key) || 'null')
      let n = cached && Date.now() - cached.t < 3_600_000 ? cached.n : null
      if (n === null) {
        const res = await fetch(url)
        if (!res.ok) return
        n = pick(await res.json())
        sessionStorage.setItem(key, JSON.stringify({ n, t: Date.now() }))
      }
      out.textContent = fmt(n)
      wrap.hidden = false
    } catch { /* plain link is fine */ }
  }
  liveCount(
    '.gh', 'acw:demo:stars',
    'https://api.github.com/repos/eeegoloauq/astro-chat-widget',
    (d) => d.stargazers_count, compact
  )
  liveCount(
    '.npm', 'acw:demo:downloads',
    'https://api.npmjs.org/downloads/point/last-week/astro-chat-widget',
    (d) => d.downloads, (n) => compact(n) + '/wk'
  )

  // Click-to-copy on the install command; the icon confirms instead of a toast.
  const install = document.querySelector<HTMLButtonElement>('.install')
  install?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('npm install astro-chat-widget')
      install.classList.add('is-copied')
      window.setTimeout(() => install.classList.remove('is-copied'), 1600)
    } catch { /* clipboard unavailable — the text is right there to select */ }
  })
</script>

<style>
  :root {
    color-scheme: dark;
  }
  body {
    margin: 0;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    font-family: ui-sans-serif, system-ui, sans-serif;
    color: rgba(255, 255, 255, 0.9);
    background:
      radial-gradient(60rem 40rem at 80% -10%, rgba(83, 109, 254, 0.18), transparent 60%),
      radial-gradient(50rem 35rem at -10% 110%, rgba(83, 109, 254, 0.1), transparent 60%),
      #0c0c10;
  }
  main {
    padding: 2.5rem 1.5rem;
    text-align: center;
  }
  h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.7rem, 4vw, 2.3rem);
    letter-spacing: -0.02em;
    color: #fff;
  }
  .hint {
    margin: 0 0 1.1rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.68);
  }

  /* Corner pills (GitHub, npm) — same glass vocabulary as the browser chrome below. */
  .corner {
    position: fixed;
    top: max(1rem, env(safe-area-inset-top));
    right: max(1rem, env(safe-area-inset-right));
    z-index: 10;
    display: flex;
    gap: 0.5rem;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.85rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.07);
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.78);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .pill:hover {
    border-color: rgba(142, 162, 255, 0.55);
    background: rgba(142, 162, 255, 0.1);
    color: #fff;
  }
  .count {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding-left: 0.55rem;
    border-left: 1px solid rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.65);
    font-variant-numeric: tabular-nums;
  }
  .pill.gh:hover .count {
    color: #ffd76e;
  }
  .pill.npm:hover .count {
    color: #ff8a80;
  }

  /* Copyable install command. */
  .install {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0 0 2.25rem;
    padding: 0.5rem 0.95rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.3);
    color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .install:hover {
    border-color: rgba(142, 162, 255, 0.55);
    color: rgba(255, 255, 255, 0.8);
  }
  .install code {
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.85rem;
  }
  .install code::before {
    content: '$ ';
    color: rgba(142, 162, 255, 0.75);
  }
  .install .install-check {
    display: none;
    color: #7ce38b;
  }
  .install.is-copied .install-copy {
    display: none;
  }
  .install.is-copied .install-check {
    display: block;
  }
  /* Opens the chat via the widget's own data-acw-open hook (see AIChat.astro). */
  .hint a {
    color: #8ea2ff;
    text-decoration-color: rgba(142, 162, 255, 0.45);
    text-underline-offset: 3px;
  }
  .frames {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
  }
  .device {
    margin: 0;
  }
  .device figcaption {
    margin-top: 0.9rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
  }
  code {
    font-family: ui-monospace, monospace;
    font-size: 0.95em;
    color: rgba(255, 255, 255, 0.75);
  }
  /* All frames are "gifs", not a second interactive instance — the corner
     FAB is the live one. */
  .device iframe {
    pointer-events: none;
    border: none;
    display: block;
  }

  /* Phone: the iframe viewport is under the widget's 768px breakpoint, so
     the panel opens as the fullscreen mobile sheet. */
  .device--phone iframe {
    width: min(330px, 84vw);
    height: 600px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 24px;
    background: #0c0c10;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
  }

  /* Desktop: a wide iframe (>768px → floating panel mode) scaled down into
     a browser-window frame. */
  .device--desktop .chrome {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.55rem 0.9rem;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-bottom: none;
    border-radius: 14px 14px 0 0;
  }
  .chrome-dots {
    display: inline-flex;
    gap: 6px;
  }
  .chrome-dots i {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.22);
  }
  .chrome-url {
    flex: 1;
    max-width: 16rem;
    margin-inline: auto;
    padding: 0.15rem 0.9rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.3);
    font-family: ui-monospace, monospace;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.45);
  }
  .chrome-viewport {
    width: 750px;
    height: 465px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-top: none;
    border-radius: 0 0 14px 14px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
  }
  .device--desktop iframe {
    width: 1000px;
    height: 620px;
    transform: scale(0.75);
    transform-origin: top left;
  }
  /* On an actual phone the desktop frame can't fit readably — and the real
     widget in the corner already gives the mobile experience first-hand. */
  @media (max-width: 880px) {
    .device--desktop {
      display: none;
    }
  }
</style>
