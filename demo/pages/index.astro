---
/**
 * Demo playground — default theme, mock SSE backend (./api/chat.ts).
 * Run with `npm run demo`. Also the stage for README screenshots.
 *
 * The two frames are iframes of ./embed.astro — the live widget playing a
 * scripted conversation on a loop (a "gif" that can't go stale): the desktop
 * glass panel over a light skeleton page, and the mobile sheet rebranded via
 * ?accent. The real interactive instance is the FAB in the corner.
 */
import AIChat from '../../src/AIChat.astro'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover, interactive-widget=resizes-content"
    />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>&#128172;</text></svg>" />
    <title>astro-chat-widget — demo</title>
  </head>
  <body>
    <main>
      <h1>astro-chat-widget</h1>
      <p class="hint">
        Live demo, mock backend — try it yourself:
        <a href="#chat" data-acw-open>the bubble ↘</a>
      </p>

      <div class="frames" aria-hidden="true">
        <figure class="device device--desktop">
          <div class="chrome">
            <span class="chrome-dots"><i></i><i></i><i></i></span>
            <span class="chrome-url">yoursite.dev</span>
          </div>
          <div class="chrome-viewport">
            <iframe src="/embed?desktop" title="" tabindex="-1"></iframe>
          </div>
          <figcaption><code>&lt;AIChat endpoint="/api/chat" /&gt;</code></figcaption>
        </figure>

        <figure class="device device--phone">
          <iframe src="/embed?accent=%23e31e24&start=2&lag=4800" title="" tabindex="-1"></iframe>
          <figcaption><code>--acw-accent: #e31e24</code></figcaption>
        </figure>
      </div>
    </main>

    <AIChat
      endpoint="/api/chat"
      feedbackEndpoint="/api/feedback"
      quickReplies={[
        {
          text: 'What can this widget do?',
          answer: [
            'Everything on this page ships as **one Astro component**:',
            '',
            '- Streaming answers over SSE, markdown rendered append-only',
            '- Native `<dialog>` — modal on desktop, iOS-keyboard-proof sheet on mobile',
            '- Theming via `--acw-*` tokens — one accent variable to rebrand',
            '- FAQ chips like this one answer **instantly, without a backend call**',
            '',
            'Zero framework runtime, one dependency.',
          ].join('\n'),
          followUps: [
            {
              text: 'Does it need a backend?',
              answer: [
                'For AI answers, yes — any endpoint speaking the tiny SSE protocol from the README (`{chunk}` events, then `{done}`).',
                '',
                'But chips with a canned `answer` — like this one — render locally. A pure FAQ tree needs **no backend at all**.',
              ].join('\n'),
              followUps: [{ text: 'How do I theme it?' }],
            },
            { text: 'Show markdown rendering' },
          ],
        },
        { text: 'How do I theme it?' },
        { text: 'What about the iOS keyboard?' },
      ]}
    />
  </body>
</html>

<style>
  :root {
    color-scheme: dark;
  }
  body {
    margin: 0;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    font-family: ui-sans-serif, system-ui, sans-serif;
    color: rgba(255, 255, 255, 0.9);
    background:
      radial-gradient(60rem 40rem at 80% -10%, rgba(83, 109, 254, 0.18), transparent 60%),
      radial-gradient(50rem 35rem at -10% 110%, rgba(83, 109, 254, 0.1), transparent 60%),
      #0c0c10;
  }
  main {
    padding: 2.5rem 1.5rem;
    text-align: center;
  }
  h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.7rem, 4vw, 2.3rem);
    letter-spacing: -0.02em;
    color: #fff;
  }
  .hint {
    margin: 0 0 2rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.68);
  }
  /* Opens the chat via the widget's own data-acw-open hook (see AIChat.astro). */
  .hint a {
    color: #8ea2ff;
    text-decoration-color: rgba(142, 162, 255, 0.45);
    text-underline-offset: 3px;
  }
  .frames {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 2.5rem;
  }
  .device {
    margin: 0;
  }
  .device figcaption {
    margin-top: 0.9rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
  }
  code {
    font-family: ui-monospace, monospace;
    font-size: 0.95em;
    color: rgba(255, 255, 255, 0.75);
  }
  /* All frames are "gifs", not a second interactive instance — the corner
     FAB is the live one. */
  .device iframe {
    pointer-events: none;
    border: none;
    display: block;
  }

  /* Phone: the iframe viewport is under the widget's 768px breakpoint, so
     the panel opens as the fullscreen mobile sheet. */
  .device--phone iframe {
    width: min(330px, 84vw);
    height: 600px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 24px;
    background: #0c0c10;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
  }

  /* Desktop: a wide iframe (>768px → floating panel mode) scaled down into
     a browser-window frame. */
  .device--desktop .chrome {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.55rem 0.9rem;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-bottom: none;
    border-radius: 14px 14px 0 0;
  }
  .chrome-dots {
    display: inline-flex;
    gap: 6px;
  }
  .chrome-dots i {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.22);
  }
  .chrome-url {
    flex: 1;
    max-width: 16rem;
    margin-inline: auto;
    padding: 0.15rem 0.9rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.3);
    font-family: ui-monospace, monospace;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.45);
  }
  .chrome-viewport {
    width: 750px;
    height: 465px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-top: none;
    border-radius: 0 0 14px 14px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.45);
  }
  .device--desktop iframe {
    width: 1000px;
    height: 620px;
    transform: scale(0.75);
    transform-origin: top left;
  }
  /* On an actual phone the desktop frame can't fit readably — and the real
     widget in the corner already gives the mobile experience first-hand. */
  @media (max-width: 880px) {
    .device--desktop {
      display: none;
    }
  }
</style>
