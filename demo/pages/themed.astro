---
/**
 * Theming demo: the same widget, rebranded with a single accent override
 * (plus a matching page background). Compare with / (default indigo).
 */
import AIChat from '../../src/AIChat.astro'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover, interactive-widget=resizes-content"
    />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>&#128172;</text></svg>" />
    <title>astro-chat-widget — themed</title>
  </head>
  <body>
    <main>
      <p class="badge">themed</p>
      <h1>One variable to rebrand</h1>
      <pre><code>:root &#123;
  --acw-accent: #e31e24;
&#125;</code></pre>
      <p class="tagline">
        Every color in the widget derives from <code>--acw-accent</code> via
        <code>color-mix()</code> — hover, gradients, glows, focus rings.
        Individual tokens stay overridable when a brand needs exact values.
      </p>
      <nav>
        <a href="/">← Back to the default theme</a>
      </nav>
    </main>

    <AIChat
      endpoint="/api/chat"
      feedbackEndpoint="/api/feedback"
      strings={{ title: 'Brand assistant' }}
      quickReplies={[
        { text: 'How do I theme it?', emoji: '🎨' },
        { text: 'Show markdown rendering', emoji: '📝' },
      ]}
    />
  </body>
</html>

<style is:global>
  :root {
    --acw-accent: #e31e24;
  }
</style>

<style>
  :root {
    color-scheme: dark;
  }
  body {
    margin: 0;
    min-height: 100dvh;
    display: grid;
    place-items: center;
    font-family: ui-sans-serif, system-ui, sans-serif;
    color: rgba(255, 255, 255, 0.9);
    background:
      radial-gradient(60rem 40rem at 80% -10%, rgba(227, 30, 36, 0.16), transparent 60%),
      radial-gradient(50rem 35rem at -10% 110%, rgba(227, 30, 36, 0.09), transparent 60%),
      #100c0c;
  }
  main {
    max-width: 34rem;
    padding: 2rem;
    text-align: center;
  }
  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    font-family: ui-monospace, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }
  h1 {
    margin: 1rem 0 0.75rem;
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    letter-spacing: -0.02em;
  }
  pre {
    display: inline-block;
    margin: 0 0 0.75rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    background: rgba(0, 0, 0, 0.35);
    text-align: left;
  }
  code {
    font-family: ui-monospace, monospace;
    font-size: 0.9em;
    color: rgba(255, 255, 255, 0.85);
  }
  .tagline {
    font-size: 1rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.65);
  }
  nav {
    margin-top: 1.5rem;
  }
  nav a {
    font-size: 0.9rem;
    color: #ff8a8e;
  }
</style>
